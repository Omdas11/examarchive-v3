# Appwrite – public (exposed to the browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-appwrite-project-id
NEXT_PUBLIC_APPWRITE_BUCKET_ID=papers
NEXT_PUBLIC_APPWRITE_SYLLABUS_BUCKET_ID=syllabus-files

# Appwrite – server-only (never prefix with NEXT_PUBLIC_)
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_BUCKET_ID=papers
APPWRITE_AVATARS_BUCKET_ID=avatars
APPWRITE_SYLLABUS_BUCKET_ID=syllabus-files

# Your deployed site origin (used for magic-link email redirects).
# Set to https://your-domain.com in production; Vercel sets this automatically
# via VERCEL_PROJECT_PRODUCTION_URL or you can pin it here.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Dev-only debug panel.  Set to "true" in .env.local to enable the floating
# debug panel.  Never set this in production or publicly accessible environments.
# Requires NODE_ENV !== "production" as well.
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=false

# OpenRouter API key for server-side AI routes (/api/ai/chat and /api/ai/generate)
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional: comma-separated allowlist of OpenRouter model IDs that have $0 prompt + completion cost
# Example: meta-llama/llama-3.1-8b-instruct:free,mistralai/mistral-7b-instruct:free
# OPENROUTER_MODEL_ALLOWLIST=
# Optional: app metadata for OpenRouter headers
# OPENROUTER_APP_URL=https://your-domain.com
# OPENROUTER_APP_NAME=ExamArchive

# Google Gemini (primary/default model; falls back to OpenRouter if unavailable)
GEMINI_API_KEY=your-gemini-api-key
# Optional: override Gemini model (default: gemini-3.1-flash-lite-preview)
# GEMINI_MODEL_ID=gemini-3.1-flash-lite-preview

# Embeddings provider key for Appwrite-only RAG chunk storage
OPENAI_API_KEY=your-openai-api-key

# Tavily-style server-side web search
TAVILY_API_KEY=your-tavily-api-key
# Optional override endpoint for compatible Tavily-style providers
# TAVILY_SEARCH_URL=https://api.tavily.com/search

# ── Appwrite collections to create manually in the console ────────────────
#
# site_metrics  (collection ID: "site_metrics")
#   Attributes: visitor_count (integer, default 0), launch_progress (integer, default 40)
#   Create a single document with ID "singleton" to hold the global counters.
#   Permissions: read(any), write(server-key only)
#
# feedback  (collection ID: "feedback")
#   Attributes: name (string), university (string), text (string), approved (boolean, default false)
#   Permissions: read(users), write(users), update/delete(server-key only)
