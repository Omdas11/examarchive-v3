# Appwrite – public (exposed to the browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-appwrite-project-id
NEXT_PUBLIC_APPWRITE_BUCKET_ID=papers
NEXT_PUBLIC_APPWRITE_SYLLABUS_BUCKET_ID=syllabus-files

# Appwrite – server-only (never prefix with NEXT_PUBLIC_)
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_BUCKET_ID=papers
APPWRITE_AVATARS_BUCKET_ID=avatars
APPWRITE_SYLLABUS_BUCKET_ID=syllabus-files
APPWRITE_SYLLABUS_MD_INGESTION_BUCKET_ID=examarchive-syllabus-md-ingestion
APPWRITE_QUESTION_INGESTION_ASSETS_BUCKET_ID=examarchive_question_ingest_assets
APPWRITE_MD_CACHE_BUCKET_ID=examarchive-md-bucket

# Your deployed site origin (used for magic-link email redirects).
# Set to https://your-domain.com in production; Vercel sets this automatically
# via VERCEL_PROJECT_PRODUCTION_URL or you can pin it here.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Analytics 4 (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Simple Analytics (optional privacy-first pageview tracker)
# Set enabled to "true" to load the script; hostname is optional override.
NEXT_PUBLIC_SIMPLE_ANALYTICS_ENABLED=false
# NEXT_PUBLIC_SIMPLE_ANALYTICS_HOSTNAME=examarchive.dev

# Dev-only debug panel.  Set to "true" in .env.local to enable the floating
# debug panel.  Never set this in production or publicly accessible environments.
# Requires NODE_ENV !== "production" as well.
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=false

# Google Gemini (primary/default model)
GEMINI_API_KEY=your-gemini-api-key
# Optional: override Gemini model (default: gemini-3.1-flash-lite-preview)
# GEMINI_MODEL_ID=gemini-3.1-flash-lite-preview
# Optional: Gemini request timeout in milliseconds (default: 45000)
# GEMINI_REQUEST_TIMEOUT_MS=45000
# Supported runtime-selectable models:
# - gemini-3.1-flash-lite-preview
# - gemma-4-31b-it

# Embeddings provider key for Appwrite-only RAG chunk storage
OPENAI_API_KEY=your-openai-api-key

# Tavily-style server-side web search
TAVILY_API_KEY=your-tavily-api-key
# Optional override endpoint for compatible Tavily-style providers
# TAVILY_SEARCH_URL=https://api.tavily.com/search

# Gotenberg — PDF rendering service (Hugging Face Space or any host)
# Recommended for this project: Hugging Face Docker Space URL.
GOTENBERG_URL=https://your-username-your-space-name.hf.space
# Required auth token for private HF Gotenberg Space.
# This is sent as: Authorization: Bearer <token>
GOTENBERG_AUTH_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional tuning for transient upstream instability:
# GOTENBERG_REQUEST_TIMEOUT_MS=45000
# GOTENBERG_MAX_ATTEMPTS=3
# GOTENBERG_RETRY_DELAY_MS=1500
# Admin env check endpoint:
# GET /api/ai/generate-pdf  (returns required/optional env check status for this pipeline)

# Razorpay (Electron Store top-up)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Gmail email delivery (for AI-generated PDF notifications) ─────────────
#
# When a user requests "Generate Notes" or "Solve Questions Paper", the PDF is
# generated in the background and emailed to their registered address.
#
# Steps to obtain a Gmail App Password (completely free):
#   1. Enable 2-Factor Authentication on your Google Account.
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create a new App Password for "Mail" / "Other" — copy the 16-character code.
#      You can paste it as `xxxx xxxx xxxx xxxx`, `xxxx-xxxx-xxxx-xxxx`, or `xxxxxxxxxxxxxxxx`.
#
GMAIL_EMAIL_ADDRESS=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
# Optional: override visible sender in outgoing mail (requires Gmail "Send mail as" alias setup).
# For custom domains (e.g. noreply@examarchive.dev), configure alias in Gmail/Workspace first.
# GMAIL_FROM_ADDRESS=noreply@examarchive.dev
#
# Optional SMTP override (e.g. Resend). If SMTP_HOST is set, SMTP is used instead of Gmail.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxx
# You can also use RESEND_API_KEY instead of SMTP_PASS.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# MAIL_FROM_ADDRESS=noreply@examarchive.dev

# ── Appwrite collections to create manually in the console ────────────────
#
# site_metrics  (collection ID: "site_metrics")
#   Attributes: visitor_count (integer, default 0), launch_progress (integer, default 40)
#   Create a single document with ID "singleton" to hold the global counters.
#   Permissions: read(any), write(server-key only)
#
# feedback  (collection ID: "feedback")
#   Attributes: name (string), university (string), text (string), approved (boolean, default false)
#   Permissions: read(users), write(users), update/delete(server-key only)
