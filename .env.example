# Supabase – required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Your deployed site origin (used for magic-link email redirects).
# Set to https://your-domain.com in production; Vercel sets this automatically
# via VERCEL_PROJECT_PRODUCTION_URL or you can pin it here.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Only needed on the server (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Appwrite – server-only (never prefix with NEXT_PUBLIC_)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_BUCKET_ID=your-appwrite-bucket-id
