{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "schedule": [
    "before 5am on Monday"
  ],
  "packageRules": [
    {
      "matchPackagePatterns": [".*"],
      "groupName": "All dependencies",
      "groupSlug": "all-dependencies"
    }
  ]
}
